<?xml version="1.0" encoding="utf-8"?>
<!-- Main Screen: Shows total items packed and navigation buttons -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/dark_background"
    android:padding="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🏕"
        android:textSize="64sp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Campsite Commander"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/forest_green"
        android:layout_marginBottom="32dp"/>

    <!-- Total items packed — updated via loop in MainActivity -->
    <TextView
        android:id="@+id/tvTotalItems"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Total Items Packed: 0"
        android:textSize="18sp"
        android:textColor="@color/cream_white"
        android:textStyle="bold"
        android:background="@color/dark_card"
        android:padding="20dp"
        android:gravity="center"
        android:layout_marginBottom="40dp"/>

    <!-- Add Gear Button -->
    <Button
        android:id="@+id/btnAddGear"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="➕  Add Gear"
        android:textSize="16sp"
        android:textColor="@color/dark_background"
        android:backgroundTint="@color/forest_green"
        android:layout_marginBottom="16dp"/>

    <!-- View Gear List Button -->
    <Button
        android:id="@+id/btnViewGear"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="🎒  View Gear List"
        android:textSize="16sp"
        android:textColor="@color/dark_background"
        android:backgroundTint="@color/earth_brown"/>

</LinearLayout>
